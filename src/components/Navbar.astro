---
interface NavLink {
  label: string;
  href: string;
}

const navLinks: NavLink[] = [
  { label: 'CHRONICLES', href: '#chronicles' },
  { label: 'FEATURES', href: '#features' },
  { label: 'COMMUNITY', href: '#community' },
  { label: 'SUPPORT', href: '#support' },
];
---

<nav class="fixed top-0 left-0 right-0 z-[1000] bg-black/95 backdrop-blur-lg border-b border-primary/10" role="navigation" aria-label="Main navigation">
  <div class="max-w-[1400px] mx-auto px-4 md:px-8 py-3 md:py-4 flex items-center justify-between gap-8 md:gap-12">
    <a href="/" class="nav-logo" aria-label="Minecraft Update Home">
      MINECRAFT UPDATE
    </a>
    
    <ul class="hidden md:flex list-none gap-10 m-0 p-0" role="list">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="nav-link">
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    
    <a href="#get-update" class="nav-cta">
      GET THE UPDATE
    </a>
  </div>
</nav>

<style is:global>
  @reference "../styles/global.css";

  .nav-logo {
    font-family: 'Space Grotesk', sans-serif;
    @apply text-base md:text-lg font-bold tracking-wider text-primary no-underline transition-colors duration-200;
  }

  .nav-logo:hover,
  .nav-logo:focus-visible {
    @apply text-white no-underline;
  }

  .nav-link {
    font-family: 'Work Sans', sans-serif;
    @apply text-xs font-medium tracking-widest text-primary no-underline py-2 relative transition-colors duration-200;
  }

  .nav-link::after {
    content: '';
    @apply absolute bottom-0 left-0 right-0 h-0.5 bg-primary scale-x-0 transition-transform duration-200;
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    @apply text-white no-underline;
  }

  .nav-link:hover::after,
  .nav-link:focus-visible::after {
    @apply scale-x-100;
  }

  .nav-cta {
    font-family: 'Work Sans', sans-serif;
    @apply text-xs font-semibold tracking-widest text-black bg-primary px-4 md:px-6 py-2 md:py-3 no-underline transition-all duration-200;
  }

  .nav-cta:hover,
  .nav-cta:focus-visible {
    @apply bg-white text-black no-underline -translate-y-0.5;
  }
</style>
